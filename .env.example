# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Binance API credentials ───────────────────────────────────────────────────
# Create at: binance.com -> Profile -> API Management -> Create API (System-generated)
# Permissions needed: Enable Reading + Enable Spot & Margin Trading
# Keep withdrawals DISABLED
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here

# ── Safety ────────────────────────────────────────────────────────────────────
# Keep TESTNET=true until you have backtested and paper traded successfully
# Set to false only when ready for real money
TESTNET=true

# Set to true to trade USDT-margined perpetual futures (allows shorting)
USE_FUTURES=false

# Your account balance in USDT (used as fallback if API balance fetch fails)
ACCOUNT_BALANCE=1000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Telegram notifications ────────────────────────────────────────────────────
# Setup:
#   1. Message @BotFather on Telegram -> /newbot -> copy the token
#   2. Send any message to your new bot (to activate the chat)
#   3. Run: python main.py telegram-test   <- auto-detects and saves your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
